<Page x:Class="Car_sharingDB.Views.ClientsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Клиенты" Background="#F4FAF8">
    <Grid Margin="28,24,28,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Клиенты" Style="{StaticResource PageTitle}"/>

        <Border Grid.Row="1" BorderBrush="#B2DFDB" BorderThickness="1"
                CornerRadius="6" Background="White" Width="260"
                HorizontalAlignment="Left" Margin="0,0,0,12">
            <TextBox x:Name="TxtSearch" BorderThickness="0" Background="Transparent"
                     Height="34" Padding="10,0" VerticalContentAlignment="Center"
                     FontSize="13" TextChanged="TxtSearch_TextChanged"/>
        </Border>

        <DataGrid Grid.Row="2" x:Name="ClientsGrid"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single" GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column" RowBackground="White"
                  AlternatingRowBackground="#F0FBF8"
                  BorderBrush="#D5E8E3" BorderThickness="1"
                  HorizontalGridLinesBrush="#E8F5F0"
                  CanUserResizeRows="False" FontSize="13"
                  RowHeight="36" ColumnHeaderHeight="40">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#1A8A6E"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Padding" Value="12,0"/>
                    <Setter Property="BorderThickness" Value="0"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"           Binding="{Binding ID_Client}"     Width="55"/>
                <DataGridTextColumn Header="Фамилия"      Binding="{Binding Surname}"        Width="140"/>
                <DataGridTextColumn Header="Имя"          Binding="{Binding Name}"           Width="120"/>
                <DataGridTextColumn Header="Отчество"     Binding="{Binding Father_name}"    Width="140"/>
                <DataGridTextColumn Header="Дата рожд."   Binding="{Binding Date_of_birth, StringFormat=dd.MM.yyyy}" Width="100"/>
                <DataGridTextColumn Header="Телефон"      Binding="{Binding Phone_number}"   Width="130"/>
                <DataGridTextColumn Header="Вод. удост."  Binding="{Binding License}"        Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="3" Background="White" BorderBrush="#D5E8E3"
                BorderThickness="0,1,0,0" Padding="0,12,0,4">
            <StackPanel Orientation="Horizontal">
                <Button Content="＋  Добавить" Width="130" Height="36"
                        Style="{StaticResource PrimaryButton}"
                        Click="BtnAdd_Click" Margin="0,0,8,0"/>
                <Button Content="✏  Изменить" Width="130" Height="36"
                        Style="{StaticResource SecondaryButton}"
                        Click="BtnEdit_Click" Margin="0,0,8,0"/>
                <Button Content="✕  Удалить" Width="130" Height="36"
                        Style="{StaticResource DangerButton}"
                        Click="BtnDelete_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
