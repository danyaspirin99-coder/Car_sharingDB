<Window x:Class="Car_sharingDB.Views.PaymentAddWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавить платёж" Height="400" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" Background="#F4FAF8">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Добавить платёж"
                   FontSize="20" FontWeight="Bold" Foreground="#1A3C34" Margin="0,0,0,16"/>

        <StackPanel Grid.Row="1">
            <TextBlock Text="Клиент *" Style="{StaticResource Label}"/>
            <ComboBox x:Name="CmbClient" Style="{StaticResource Combo}"
                      DisplayMemberPath="FullName"/>

            <TextBlock Text="Тип платежа *" Style="{StaticResource Label}"/>
            <ComboBox x:Name="CmbType" Style="{StaticResource Combo}">
                <ComboBoxItem Content="Плата за аренду"/>
                <ComboBoxItem Content="Штраф"/>
                <ComboBoxItem Content="Ремонт"/>
            </ComboBox>

            <TextBlock Text="Способ оплаты *" Style="{StaticResource Label}"/>
            <ComboBox x:Name="CmbWay" Style="{StaticResource Combo}">
                <ComboBoxItem Content="Карта"/>
                <ComboBoxItem Content="Наличные"/>
                <ComboBoxItem Content="QR-код"/>
            </ComboBox>

            <TextBlock Text="Сумма *" Style="{StaticResource Label}"/>
            <TextBox x:Name="TxtAmount" Style="{StaticResource Input}" MaxLength="10"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Отмена" Width="90" Height="32" Margin="0,0,8,0"
                    Click="BtnCancel_Click"
                    Background="#95A5A6" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            <Button Content="Сохранить" Width="100" Height="32"
                    Style="{StaticResource PrimaryButton}" Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>
