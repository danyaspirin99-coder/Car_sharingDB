<Window x:Class="Car_sharingDB.Views.ClientEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Клиент" Height="500" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" Background="#F4FAF8">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TxtTitle" Grid.Row="0" Text="Добавить клиента"
                   FontSize="20" FontWeight="Bold" Foreground="#1A3C34" Margin="0,0,0,16"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Фамилия *" Style="{StaticResource Label}"/>
                <TextBox x:Name="TxtSurname" Style="{StaticResource Input}" MaxLength="50"/>

                <TextBlock Text="Имя *" Style="{StaticResource Label}"/>
                <TextBox x:Name="TxtName" Style="{StaticResource Input}" MaxLength="50"/>

                <TextBlock Text="Отчество" Style="{StaticResource Label}"/>
                <TextBox x:Name="TxtFatherName" Style="{StaticResource Input}" MaxLength="50"/>

                <TextBlock Text="Дата рождения *" Style="{StaticResource Label}"/>
                <DatePicker Foreground="#1C2833" x:Name="DpBirthDate" Height="30" BorderBrush="#B2DFDB"/>

                <TextBlock Text="Номер телефона *" Style="{StaticResource Label}"/>
                <TextBox x:Name="TxtPhone" Style="{StaticResource Input}" MaxLength="20"/>

                <TextBlock Text="Вод. удостоверение *" Style="{StaticResource Label}"/>
                <TextBox x:Name="TxtLicense" Style="{StaticResource Input}" MaxLength="50"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Отмена" Width="90" Height="32" Margin="0,0,8,0"
                    Click="BtnCancel_Click"
                    Background="#95A5A6" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            <Button Content="Сохранить" Width="100" Height="32"
                    Style="{StaticResource PrimaryButton}" Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>
