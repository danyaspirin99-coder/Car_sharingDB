<Window x:Class="Car_sharingDB.Views.AccessoryAddWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавить аксессуар" Height="280" Width="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" Background="#F4FAF8">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Добавить аксессуар"
                   FontSize="20" FontWeight="Bold" Foreground="#1A3C34" Margin="0,0,0,16"/>

        <StackPanel Grid.Row="1">
            <TextBlock Text="Автомобиль *" Style="{StaticResource Label}"/>
            <ComboBox x:Name="CmbVehicle" Style="{StaticResource Combo}"
                      DisplayMemberPath="DisplayInfo"/>

            <TextBlock Text="Аксессуар *" Style="{StaticResource Label}"/>
            <ComboBox x:Name="CmbAccessory" Style="{StaticResource Combo}">
                <ComboBoxItem Content="Детское кресло"/>
                <ComboBoxItem Content="Кабриолет"/>
                <ComboBoxItem Content="Кондиционер"/>
                <ComboBoxItem Content="багаж на крыше"/>
            </ComboBox>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Отмена" Width="90" Height="32" Margin="0,0,8,0"
                    Click="BtnCancel_Click"
                    Background="#95A5A6" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            <Button Content="Сохранить" Width="100" Height="32"
                    Style="{StaticResource PrimaryButton}" Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>
