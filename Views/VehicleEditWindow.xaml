<Window x:Class="Car_sharingDB.Views.VehicleEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Автомобиль" Height="580" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock x:Name="TxtTitle" Grid.Row="0" Text="Добавить автомобиль"
                   FontSize="18" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,20"/>

        <!-- Форма -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
          <StackPanel>

            <TextBlock Text="Гос. номер *" Style="{StaticResource Label}"/>
            <TextBox x:Name="TxtNumber" Style="{StaticResource Input}" MaxLength="10"/>

            <TextBlock Text="Модель *" Style="{StaticResource Label}"/>
            <TextBox x:Name="TxtModel" Style="{StaticResource Input}" MaxLength="50"/>

            <TextBlock Text="Тип топлива *" Style="{StaticResource Label}"/>
            <ComboBox x:Name="CmbFuel" Style="{StaticResource Combo}">
                <ComboBoxItem Content="Бензин"/>
                <ComboBoxItem Content="Дизель"/>
                <ComboBoxItem Content="Электро"/>
            </ComboBox>

            <TextBlock Text="Год выпуска *" Style="{StaticResource Label}"/>
            <TextBox x:Name="TxtYear" Style="{StaticResource Input}" MaxLength="4"/>

            <TextBlock Text="Цвет *" Style="{StaticResource Label}"/>
            <TextBox x:Name="TxtColor" Style="{StaticResource Input}" MaxLength="50"/>

            <TextBlock Text="КПП *" Style="{StaticResource Label}"/>
            <ComboBox x:Name="CmbTransmission" Style="{StaticResource Combo}">
                <ComboBoxItem Content="Автомат"/>
                <ComboBoxItem Content="Механика"/>
            </ComboBox>

            <TextBlock Text="Привод *" Style="{StaticResource Label}"/>
            <ComboBox x:Name="CmbDrive" Style="{StaticResource Combo}">
                <ComboBoxItem Content="Полный"/>
                <ComboBoxItem Content="Задний"/>
                <ComboBoxItem Content="Передний"/>
            </ComboBox>

            <TextBlock Text="Статус *" Style="{StaticResource Label}"/>
            <ComboBox x:Name="CmbStatus" Style="{StaticResource Combo}">
                <ComboBoxItem Content="Доступно"/>
                <ComboBoxItem Content="Забронировано"/>
                <ComboBoxItem Content="На обслуживании"/>
            </ComboBox>
        </StackPanel>
        </ScrollViewer>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Отмена" Width="90" Height="32" Margin="0,0,8,0"
                    Click="BtnCancel_Click"
                    Background="#BDC3C7" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            <Button Content="Сохранить" Width="100" Height="32"
                    Click="BtnSave_Click"
                    Background="#2980B9" Foreground="White" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </Grid>

    <Window.Resources>
        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="Margin" Value="0,8,0,3"/>
        </Style>
        <Style x:Key="Input" TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#CCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style x:Key="Combo" TargetType="ComboBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="5,0"/>
            <Setter Property="BorderBrush" Value="#CCC"/>
        </Style>
    </Window.Resources>
</Window>
