<Window x:Class="Car_sharingDB.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CarSharing" Height="460" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F4FAF8">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="160"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Grid.Row="0" Background="#1A3C34">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="🚗" FontSize="40" HorizontalAlignment="Center"/>
                <TextBlock Text="CarSharing" Foreground="White"
                           FontSize="24" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
                <TextBlock Text="Система управления каршерингом"
                           Foreground="#A8D5C8" FontSize="12"
                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Форма -->
        <StackPanel Grid.Row="1" Margin="40,28,40,28">
            <TextBlock Text="Логин" Style="{StaticResource Label}"/>
            <TextBox x:Name="TxtUsername" Style="{StaticResource Input}" Margin="0,0,0,4"/>

            <TextBlock Text="Пароль" Style="{StaticResource Label}"/>
            <Border BorderBrush="#B2DFDB" BorderThickness="1" CornerRadius="6"
                    Background="White" Margin="0,0,0,20">
                <PasswordBox x:Name="PbPassword" Height="32"
                             Padding="10,0" BorderThickness="0"
                             Background="Transparent" FontSize="13"
                             KeyDown="PbPassword_KeyDown"/>
            </Border>

            <Button Content="Войти" Height="40"
                    Style="{StaticResource PrimaryButton}"
                    Click="BtnLogin_Click"/>

            <TextBlock x:Name="TxtError" Margin="0,12,0,0"
                       Foreground="#E74C3C" FontSize="12"
                       HorizontalAlignment="Center" Visibility="Collapsed"/>
        </StackPanel>
    </Grid>
</Window>
